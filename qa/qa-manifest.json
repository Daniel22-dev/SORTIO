{
  "standard": "GHRAB-QA-1.0.2",
  "appId": "sortio",
  "appName": "SORTIO – Organizátor třídy",
  "appVersion": "1.0.2",
  "entryPoint": "dist/index.html",
  "serveRoot": "dist",
  "buildRoot": "dist",
  "installCommand": "npm ci --no-fund",
  "buildCommand": "npm run build",
  "testCommand": "npm test && npm run test:internal",
  "auditCommand": "npm audit --audit-level=high",
  "features": {
    "pwa": true,
    "ai": false,
    "centralAccessGuard": true,
    "fileExport": true,
    "studentRuntime": false,
    "teacherRuntime": true,
    "localStorage": true,
    "serviceWorker": true
  },
  "requiredViewports": [
    {
      "width": 360,
      "height": 800
    },
    {
      "width": 412,
      "height": 915
    },
    {
      "width": 768,
      "height": 1024
    },
    {
      "width": 1366,
      "height": 768
    },
    {
      "width": 1920,
      "height": 1080
    }
  ],
  "versionChecks": [
    {
      "file": "package.json",
      "regex": "\\\"version\\\"\\s*:\\s*\\\"([0-9.]+)\\\"",
      "expected": "1.0.2"
    },
    {
      "file": "dist/studio-manifest.json",
      "regex": "\\\"version\\\"\\s*:\\s*\\\"([0-9.]+)\\\"",
      "expected": "1.0.2"
    },
    {
      "file": "dist/sw.js",
      "regex": "sortio-v([0-9.]+)",
      "expected": "1.0.2"
    }
  ],
  "pwaTargets": [
    {
      "id": "sortio",
      "root": "dist",
      "manifest": "manifest.webmanifest",
      "serviceWorker": "sw.js",
      "cachePrefix": "sortio-v"
    }
  ],
  "security": {
    "allowedEmails": [],
    "requiresCsvFormulaProtection": false,
    "validator": "qa/security-validator.mjs"
  },
  "compatibility": {
    "runtimeSourceRoots": [
      "src"
    ],
    "disallowRegexLookbehind": true
  }
}
