{
  "name": "sortio-organizator-tridy",
  "version": "1.0.2",
  "private": true,
  "description": "SORTIO – produkční local-first organizátor třídy s odolným ukládáním, diagnostikou, projekcí a tiskem",
  "type": "module",
  "scripts": {
    "build": "node scripts/build.mjs",
    "verify:structure": "node scripts/verify-structure.mjs",
